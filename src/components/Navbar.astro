---
const links = [
  { label: "Features", href: "#features" },
  { label: "Manifesto", href: "#manifesto" },
  { label: "GitHub", href: "https://github.com/nimio-app", external: true },
  { label: "Docs", href: "https://github.com/nimio-app/android", external: true }
];
---

<header class="sticky top-0 z-30 border-b border-black/5 bg-white/70 backdrop-blur-xl dark:border-white/10 dark:bg-[#0b1522]/70">
  <nav class="container-shell flex items-center justify-between py-4" aria-label="Main navigation">
    <a href="#top" class="focus-ring inline-flex items-center gap-3 rounded-full px-2 py-1">
      <span class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-nimio-ocean text-sm font-bold text-white shadow-glow">N</span>
      <span class="font-display text-lg font-semibold tracking-tight">Nimio</span>
    </a>

    <ul class="hidden items-center gap-7 md:flex">
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            target={link.external ? "_blank" : undefined}
            rel={link.external ? "noreferrer" : undefined}
            class="focus-ring rounded-md text-sm font-medium text-nimio-ink/85 transition hover:text-nimio-ocean dark:text-white/85 dark:hover:text-nimio-mint"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <a
      href="https://github.com/nimio-app/android"
      target="_blank"
      rel="noreferrer"
      class="focus-ring rounded-full bg-nimio-ink px-5 py-2.5 text-sm font-semibold text-white transition hover:-translate-y-0.5 hover:bg-nimio-ocean dark:bg-nimio-mint dark:text-[#05201b]"
    >
      Get the App
    </a>
  </nav>
</header>
