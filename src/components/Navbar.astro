---
const links = [
  { label: "Features", href: "#features" },
  { label: "Manifesto", href: "#manifesto" },
  { label: "GitHub", href: "https://github.com/nimio-app", external: true },
  { label: "Docs", href: "https://github.com/nimio-app/android", external: true }
];
---

<header class="sticky top-0 z-30 border-b border-[#5a2e3a]/10 bg-[#fff8f4]/80 backdrop-blur-xl">
  <nav class="container-shell flex items-center justify-between py-4" aria-label="Main navigation">
    <a href="#top" class="focus-ring inline-flex items-center gap-3 rounded-full px-2 py-1">
      <span class="relative inline-flex h-9 w-9 items-center justify-center overflow-hidden rounded-full bg-nimio-coral shadow-glow">
        <span class="absolute inset-0 bg-center bg-cover bg-no-repeat" style={`background-image: url('/nimio_logo.png');`} aria-hidden="true"></span>
      </span>
      <span class="font-display text-lg font-semibold tracking-tight">Nimio</span>
    </a>

    <ul class="hidden items-center gap-7 md:flex">
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            target={link.external ? "_blank" : undefined}
            rel={link.external ? "noreferrer" : undefined}
            class="focus-ring rounded-md text-sm font-medium text-nimio-ink/85 transition hover:text-nimio-ocean"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <a
      href="https://github.com/nimio-app/android"
      target="_blank"
      rel="noreferrer"
      class="focus-ring rounded-full bg-nimio-ocean px-5 py-2.5 text-sm font-semibold text-white transition hover:-translate-y-0.5 hover:bg-[#e51d5c]"
    >
      Get the App
    </a>
  </nav>
</header>
