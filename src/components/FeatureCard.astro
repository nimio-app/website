---
interface Props {
  title: string;
  description: string;
  icon: string;
}

const { title, description, icon } = Astro.props;
---

<article class="rounded-2xl border border-[#5a2e3a]/10 bg-white/80 p-6 shadow-sm backdrop-blur-sm transition hover:-translate-y-1 hover:shadow-glow">
  <p class="mb-3 text-2xl" aria-hidden="true">{icon}</p>
  <h3 class="font-display text-xl font-semibold tracking-tight">{title}</h3>
  <p class="mt-2 text-sm leading-relaxed text-nimio-ink/80">{description}</p>
</article>
