---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Hero from "../components/Hero.astro";
import FeatureCard from "../components/FeatureCard.astro";

const features = [
  {
    icon: "🟢",
    title: "Intentional States",
    description: "Set how reachable you are in plain language: Free, Busy, or Want to talk."
  },
  {
    icon: "🔒",
    title: "Granular Privacy",
    description: "Decide exactly who sees which level of detail, from close partner to broader friend circle."
  },
  {
    icon: "⏱️",
    title: "Temporary Statuses",
    description: "Set 15m, 30m, or custom windows and let statuses auto-reset when your context changes."
  },
  {
    icon: "⚡",
    title: "Android Native",
    description: "Use widgets, Quick Settings tiles, and one-tap ask-if-free nudges right from your phone."
  }
];
---

<BaseLayout
  title="Nimio | Intentional Availability"
  description="Nimio helps people share intentional availability with privacy-first controls. Open-source, zero-tracking, and built for respectful communication."
  ogImage="/og/nimio-og.svg"
>
  <Navbar />
  <main>
    <Hero />

    <section class="section-pad" id="manifesto" aria-labelledby="problem-solution-title">
      <div class="container-shell grid gap-7 lg:grid-cols-2">
        <article class="rounded-3xl border border-[#5a2e3a]/10 bg-white/80 p-8 shadow-sm">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-nimio-coral">The Problem</p>
          <h2 id="problem-solution-title" class="mt-4 font-display text-3xl font-bold tracking-tight">Online status creates pressure.</h2>
          <p class="mt-4 leading-relaxed text-nimio-ink/80">
            "I don&apos;t want to bother them." "Why didn&apos;t you text me?" Traditional online indicators collapse everything into a single signal.
            Presence gets mistaken for permission.
          </p>
        </article>

        <article class="rounded-3xl border border-nimio-ocean/30 bg-gradient-to-br from-[#fff0f6] to-[#fff7f2] p-8 shadow-sm">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-nimio-ocean">The Solution</p>
          <h2 class="mt-4 font-display text-3xl font-bold tracking-tight">Intentional context over passive presence.</h2>
          <p class="mt-4 leading-relaxed text-nimio-ink/80">
            Nimio communicates your real social bandwidth, mental energy, and preferred timing so reaching out can feel respectful and low-friction.
          </p>
        </article>
      </div>
    </section>

    <section class="section-pad" id="features" aria-labelledby="features-title">
      <div class="container-shell">
        <div class="max-w-2xl">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-nimio-ocean">Key Features</p>
          <h2 id="features-title" class="mt-3 font-display text-3xl font-bold tracking-tight md:text-4xl">
            Availability that reflects real life
          </h2>
        </div>

        <div class="mt-8 grid gap-5 md:grid-cols-2">
          {features.map((feature) => <FeatureCard {...feature} />)}
        </div>
      </div>
    </section>

    <section class="section-pad" aria-labelledby="oss-title">
      <div class="container-shell">
        <article class="rounded-3xl border border-[#5a2e3a]/10 bg-white/80 p-8 shadow-sm">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-nimio-coral">Open Source Mission</p>
          <h2 id="oss-title" class="mt-3 font-display text-3xl font-bold tracking-tight">Community-driven and privacy-first by design.</h2>
          <p class="mt-4 max-w-3xl leading-relaxed text-nimio-ink/80">
            Nimio is built in the open, inspired by projects like Immich. No surveillance logic, no productivity scoring, and no hidden behavioral tracking.
            Just humane communication infrastructure that gives people agency over when and how they connect.
          </p>

          <p class="mt-4 max-w-3xl text-sm leading-relaxed text-nimio-ink/70">
            Community: <a href="https://matrix.to/#/@nimio.app:matrix.org" target="_blank" rel="noreferrer" class="font-semibold text-nimio-ocean underline decoration-nimio-coral decoration-2 underline-offset-4">@nimio.app:matrix.org</a>
            and <a href="https://discord.gg/pNUg7sqh9" target="_blank" rel="noreferrer" class="font-semibold text-nimio-ocean underline decoration-nimio-coral decoration-2 underline-offset-4">Discord</a>.
          </p>

          <div class="mt-6 flex flex-wrap gap-3">
            <a
              href="https://github.com/nimio-app"
              target="_blank"
              rel="noreferrer"
              class="focus-ring rounded-full bg-nimio-ocean px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-[#e51d5c]"
            >
              View on GitHub
            </a>
            <a
              href="https://github.com/nimio-app/android/blob/main/LICENSE"
              target="_blank"
              rel="noreferrer"
              class="focus-ring rounded-full border border-nimio-ocean/25 bg-white/75 px-5 py-2.5 text-sm font-semibold text-nimio-ink transition hover:bg-white"
            >
              License (MIT/Apache)
            </a>
          </div>
        </article>
      </div>
    </section>
  </main>

  <footer class="border-t border-[#5a2e3a]/10 py-10">
    <div class="container-shell flex flex-col gap-4 text-sm text-nimio-ink/80 md:flex-row md:items-center md:justify-between">
      <p>
        Nimio.org • Respectful communication, open by default.
      </p>
      <div class="flex flex-wrap items-center gap-4">
        <a href="https://github.com/nimio-app" target="_blank" rel="noreferrer" class="focus-ring rounded text-inherit hover:text-nimio-ocean">GitHub</a>
        <a href="https://matrix.to/#/@nimio.app:matrix.org" target="_blank" rel="noreferrer" class="focus-ring rounded text-inherit hover:text-nimio-ocean">Matrix</a>
        <a href="https://discord.gg/pNUg7sqh9" target="_blank" rel="noreferrer" class="focus-ring rounded text-inherit hover:text-nimio-ocean">Discord</a>
      </div>
    </div>
  </footer>
</BaseLayout>
